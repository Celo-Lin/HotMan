<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hot.modules.sys.dao.SysMenuDao">

	<select id="get" resultType="com.hot.modules.sys.entity.SysMenu">
		SELECT
			id,
			parent_id AS 'parentId',
			parent_ids AS 'parentIds',
			title,
			path,
			component,
			`sign`,
			icon,
			sort,
			`type`
		FROM `sys_menu`
		WHERE id = #{id}
	</select>

	<select id="list" resultType="com.hot.modules.sys.entity.SysMenu">
		SELECT
			id,
			parent_id AS 'parentId',
			parent_ids AS 'parentIds',
			title,
			path,
			component,
			`sign`,
			icon,
			sort,
			`type`
		FROM `sys_menu`
		WHERE del_flag = 0
		ORDER BY sort ASC
	</select>

	<insert id="insert" parameterType="com.hot.modules.sys.entity.SysMenu" useGeneratedKeys="true" keyProperty="id">
		INSERT INTO `sys_menu`(
			`parent_id`,
			`parent_ids`,
			`title`,
			`path`,
			`component`,
			`sign`,
			`icon`,
			`sort`,
			`type`,
			`create_user`,
			`create_time`,
			`update_user`,
			`update_time`
		) VALUES (
			#{parentId},
			#{parentIds},
			#{title},
			#{path},
			#{component},
			#{sign},
			#{icon},
			#{sort},
			#{type},
			#{createUser},
			NOW(),
			#{createUser},
			NOW()
		)
	</insert>

	<update id="update" parameterType="com.hot.modules.sys.entity.SysMenu">
		UPDATE `sys_menu` SET
			`parent_id` = #{parentId},
			`parent_ids` = #{parentIds},
			`title` = #{title},
			`path` = #{path},
			`component` = #{component},
			`sign` = #{sign},
			`icon` = #{icon},
			`sort` = #{sort},
			`type` = #{type},
			`update_user` = #{createUser},
			`update_time` = NOW()
		WHERE id = #{id}
	</update>

	<update id="delete">
		UPDATE `sys_menu` SET
			`update_user` = #{createUser},
			`update_time` = NOW(),
			`del_flag` = 1
		WHERE id = #{id}
	</update>

	<select id="rolelist" resultType="com.hot.modules.sys.entity.SysRole">
		SELECT
			id,
			`name`,
			update_time AS 'updateTime'
		FROM `sys_menu_role`
		WHERE del_flag = 0
		<if test="name != null and name != ''">
			AND name LIKE CONCAT("%",#{name},"%")
		</if>
		ORDER BY update_time DESC
	</select>

	<resultMap id="roleMap" type="com.hot.modules.sys.entity.SysRole">
		<id property="id" column="id"/>
		<result property="name" column="name"/>
		<collection property="list" ofType="integer" column="menu_id" javaType="java.util.ArrayList">
			<id property="menuId" column="menu_id"/>
		</collection>
	</resultMap>

	<select id="roleget" resultMap="roleMap">
		SELECT
			a.id,
			a.name,
			b.`menu_id`
		FROM `sys_menu_role` a
		LEFT JOIN `sys_menu_role_data` b ON b.`menu_role_id` = a.`id`
		WHERE a.id = #{id}
	</select>

	<insert id="insertRole" parameterType="com.hot.modules.sys.entity.SysRole" useGeneratedKeys="true" keyProperty="id">
		INSERT INTO `sys_menu_role`(
			`name`,
			`create_user`,
			`create_time`,
			`update_user`,
			`update_time`
		) VALUES (
			#{name},
		    #{createUser},
			NOW(),
			#{createUser},
			NOW()
		)
	</insert>

	<update id="updateRole">
		UPDATE `sys_menu_role` SET
			`name` = #{name},
			`update_user` = #{createUser},
			`update_time` = NOW()
		WHERE id = #{id}
	</update>

	<update id="roledelete">
		UPDATE `sys_menu_role` SET
			`del_flag` = 1,
			`update_user` = #{createUser},
			`update_time` = NOW()
		WHERE id = #{id}
	</update>

	<insert id="insertRoleData">
		INSERT INTO `sys_menu_role_data`(
			`menu_id`,
			`menu_role_id`
		) VALUES
		<foreach collection="list" item="item" separator=",">
			(#{item},#{id})
		</foreach>
	</insert>

	<delete id="deleteRoleData">
		DELETE FROM `sys_menu_role_data` WHERE menu_role_id = #{id}
	</delete>

</mapper>